# =====================================================
# ByPass Transfers - Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =====================================================

# ===============================
# DATABASE
# ===============================
DB_URL=jdbc:postgresql://db:5432/bypass_records
DB_USERNAME=postgres
DB_PASSWORD=your_strong_db_password_here

# ===============================
# MAIL (Gmail SMTP)
# ===============================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_app_password_here

# ===============================
# EXCHANGE RATE API
# ===============================
EXCHANGE_RATE_API_KEY=d770690917fdd76c
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6/d770690917fdd76c/latest/USD

# ===============================
# ADMIN (First-run only)
# ===============================
ADMIN_PASSWORD=change_this_strong_password

# ===============================
# SPRING PROFILE
# ===============================
SPRING_PROFILES_ACTIVE=prod
